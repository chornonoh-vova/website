{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.chornonoh-vova.com" }],
      "destination": "https://chornonoh-vova.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://vitals.vercel-insights.com https://va.vercel-scripts.com; frame-ancestors 'none'"
        },
        {
          "key": "Link",
          "value": "</llms.txt>; rel=\"llms-txt\", </sitemap-index.xml>; rel=\"sitemap\", </rss.xml>; rel=\"alternate\"; type=\"application/rss+xml\""
        }
      ]
    }
  ]
}
