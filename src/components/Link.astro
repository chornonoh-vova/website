---
import clsx from "clsx";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  underline?: boolean;
}

const {
  underline,
  class: classNames,
  "aria-current": ariaCurrent,
  ...props
} = Astro.props;
---

<!-- biome-ignore lint/a11y/useAnchorContent: content is provided by callers via <slot />, always non-empty in practice -->
<!-- biome-ignore lint/a11y/useValidAnchor: href is provided by callers via {...props}, not statically visible here -->
<a
  class={clsx([
    "text-current decoration-black/30 hover:text-black hover:decoration-black/50 dark:decoration-white/40 hover:dark:text-white hover:dark:decoration-white/70",
    { "underline underline-offset-2": underline },
    { "font-medium": ariaCurrent === "page" },
    classNames,
  ])}
  aria-current={ariaCurrent}
  {...props}
>
  <slot />
</a>
