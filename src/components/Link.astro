---
import clsx from "clsx";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  underline?: boolean;
}

const {
  underline,
  class: classNames,
  "aria-current": ariaCurrent,
  ...props
} = Astro.props;
---

<a
  class={clsx([
    "decoration-black/30 dark:decoration-white/40 hover:decoration-black/50 hover:dark:decoration-white/70 text-current hover:text-black hover:dark:text-white",
    { "underline underline-offset-2": underline },
    { "font-medium": ariaCurrent === "page" },
    classNames,
  ])}
  aria-current={ariaCurrent}
  {...props}
>
  <slot />
</a>
